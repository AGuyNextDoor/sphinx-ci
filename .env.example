# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Database (Vercel Postgres / Neon)
# DATABASE_POSTGRES_URL: pooled connection used by the app at runtime (Neon -pooler host)
# DIRECT_URL:            direct connection used by `prisma migrate` (Neon non-pooler host)
# DATABASE_URL is also accepted as a local fallback.
DATABASE_POSTGRES_URL=postgres://...
DIRECT_URL=postgres://...

# Redis (optional, for cache)
UPSTASH_REDIS_REST_URL=...
UPSTASH_REDIS_REST_TOKEN=...

# App
NEXT_PUBLIC_APP_URL=https://sphinx-ci.dev

# GitHub OAuth (create at https://github.com/settings/developers)
GITHUB_CLIENT_ID=...
GITHUB_CLIENT_SECRET=...

# NextAuth secret (generate with: openssl rand -base64 32)
AUTH_SECRET=...
